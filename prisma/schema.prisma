generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatStatus {
  BOT
  MANAGER
  INACTIVE
}

enum MessageDirection {
  IN
  OUT
}

enum TransactionType {
  TOPUP
  CHARGE
  REFUND
  BONUS
}

model Chat {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Внешний ID чата Авито
  avitoChatId     String   @unique
  accountId       Int

  status          ChatStatus @default(BOT)
  pinned          Boolean    @default(false)

  customerName    String?
  itemTitle       String?
  price           Int?
  adUrl           String?
  chatUrl         String?

  lastMessageAt   DateTime?
  lastMessageText String?

  // Дожим бота: когда был отправлен вопрос "актуален ли заказ"
  followupSentAt  DateTime?

  unreadCount     Int @default(0)

  raw             Json @default("{}")

  messages        Message[]

  // индексы под твои сортировки и фильтры
  @@index([status, pinned, lastMessageAt])
  @@index([status, pinned, price])
}

model Message {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  chatId         String
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // внешний id сообщения (в mock/ручной отправке тоже заполняем)
  avitoMessageId String

  direction      MessageDirection
  text           String
  sentAt         DateTime
  isRead         Boolean @default(false)

  raw            Json @default("{}")

  @@unique([chatId, avitoMessageId], name: "chatId_avitoMessageId")
  @@index([chatId, sentAt])
  @@index([chatId, direction, isRead])
}

model IntegrationState {
  id           Int      @id @default(1)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  updatedAt    DateTime @updatedAt
}

// Сырые входящие события (полезно для дедупа/диагностики)
model WebhookEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  source    String
  eventId   String?
  type      String?

  payload   Json     @default("{}")

  @@index([source, createdAt])
  @@unique([source, eventId])
}
model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  role         String   @default("USER")  // "USER" | "ADMIN"

  // Per-user Avito API credentials
  avitoClientId     String?
  avitoClientSecret String?
  avitoAccountId    Int?

  // Per-user AI settings (override global defaults)
  aiEnabled        Boolean @default(true)   // выключить ИИ для чатов этого пользователя
  aiInstructions   String?
  aiEscalatePrompt String?

  // Дожим: отправлять ли напоминание "Актуален ли ваш заказ?"
  followupEnabled  Boolean @default(true)
  // Дожим: текст сообщения (null = дефолтный «Актуален ли ваш заказ?»)
  followupMessage  String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions           Session[]
  knowledgeBaseFiles KnowledgeBaseFile[]
  balance            UserBalance?
  transactions       BalanceTransaction[]
  aiBillings         AiMessageBilling[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
}

// Настройки AI-ассистента (синглтон, id=1)
model AiAssistant {
  id              Int      @id @default(1)
  enabled         Boolean  @default(false)
  provider        String?  @default("openai")  // "openai" | "deepseek"
  apiKey          String?                        // OpenAI API key
  deepseekApiKey  String?                        // DeepSeek API key
  assistantId     String?
  vectorStoreId   String?
  instructions    String?
  escalatePrompt  String?
  model           String?
  updatedAt       DateTime @updatedAt
}

// Файлы базы знаний для DeepSeek (хранятся локально в БД)
model KnowledgeBaseFile {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  filename  String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  chunks    KnowledgeBaseChunk[]

  @@index([userId])
}

// Чанки текста из файлов базы знаний
model KnowledgeBaseChunk {
  id         String   @id @default(cuid())
  fileId     String
  file       KnowledgeBaseFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int

  @@index([fileId])
}

// ─── Биллинг ─────────────────────────────────────────────────────────────────

// Конфиг биллинга (синглтон, id=1): наценка, курс, прайсы провайдеров
model BillingConfig {
  id Int @id @default(1)

  // Множитель наценки для OpenAI: 2.5 = стоимость × 2.5 (т.е. наценка 150%)
  openaiMarkupMultiplier    Decimal @db.Decimal(6, 3) @default(2.5)
  // Курс USD → RUB для OpenAI (обновляется вручную через админку)
  openaiUsdToRub            Decimal @db.Decimal(8, 4) @default(90)

  // Множитель наценки для DeepSeek
  deepseekMarkupMultiplier  Decimal @db.Decimal(6, 3) @default(2.5)
  // Курс USD → RUB для DeepSeek
  deepseekUsdToRub          Decimal @db.Decimal(8, 4) @default(90)

  // Цены OpenAI — за 1 млн токенов (USD)
  // Настраиваемые вручную (справочные рыночные цены обновляются автоматически в UI)
  gpt52InputPrice     Decimal @db.Decimal(10, 4) @default(15)
  gpt52OutputPrice    Decimal @db.Decimal(10, 4) @default(60)

  // Цены DeepSeek Chat (USD за 1 млн токенов)
  deepseekInputPrice  Decimal @db.Decimal(10, 4) @default(0.27)
  deepseekOutputPrice Decimal @db.Decimal(10, 4) @default(1.10)

  updatedAt DateTime @updatedAt
}

// Баланс пользователя (в рублях)
model UserBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @db.Decimal(12, 4) @default(0)
  updatedAt DateTime @updatedAt
}

// Детальный лог каждого AI-ответа с полным расчётом
model AiMessageBilling {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId           String

  model            String   // "gpt-5.2", "deepseek-chat" и т.д.
  inputTokens      Int
  outputTokens     Int

  // Все параметры расчёта сохраняются в момент списания (снэпшот конфига)
  inputPriceUsd    Decimal  @db.Decimal(10, 6)  // цена input токенов на момент ответа
  outputPriceUsd   Decimal  @db.Decimal(10, 6)  // цена output токенов на момент ответа
  usdToRub         Decimal  @db.Decimal(8, 4)
  markupMultiplier Decimal  @db.Decimal(6, 3)

  costUsd          Decimal  @db.Decimal(10, 6)  // себестоимость в USD
  costRub          Decimal  @db.Decimal(10, 4)  // себестоимость в RUB
  chargedRub       Decimal  @db.Decimal(10, 4)  // списано с пользователя в RUB
  profitRub        Decimal  @db.Decimal(10, 4)  // наш доход = charged - cost

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// Все движения по балансу: пополнения, списания, бонусы
model BalanceTransaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         TransactionType
  amount       Decimal         @db.Decimal(12, 4)  // + пополнение, − списание
  balanceAfter Decimal         @db.Decimal(12, 4)  // баланс после транзакции

  description  String?
  aiMessageId  String?         // ссылка на AiMessageBilling если type=CHARGE

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
