generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatStatus {
  BOT
  MANAGER
  INACTIVE
}

enum MessageDirection {
  IN
  OUT
}

enum ChatLabelColor {
  YELLOW
  RED
  BLUE
  GREEN
}

model Chat {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Внешний ID чата Авито
  avitoChatId     String   @unique
  accountId       Int

  status          ChatStatus @default(BOT)
  pinned          Boolean    @default(false)

  customerName    String?
  itemTitle       String?
  price           Int?
  adUrl           String?
  chatUrl         String?

  lastMessageAt   DateTime?
  lastMessageText String?

  // Дожим бота: когда был отправлен вопрос "актуален ли заказ"
  followupSentAt  DateTime?

  unreadCount     Int @default(0)

  // Ручная отметка "непрочитанный" (для менеджера)
  manualUnread   Boolean @default(false)

  // Метка чата (цвет) для сортировки/приоритизации
  labelColor     ChatLabelColor?

  raw             Json @default("{}")

  messages        Message[]

  // индексы под твои сортировки и фильтры
  @@index([status, pinned, lastMessageAt])
  @@index([status, pinned, price])
  @@index([labelColor])
}

model Message {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  chatId         String
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // внешний id сообщения (в mock/ручной отправке тоже заполняем)
  avitoMessageId String

  direction      MessageDirection
  text           String
  sentAt         DateTime
  isRead         Boolean @default(false)

  raw            Json @default("{}")

  @@unique([chatId, avitoMessageId], name: "chatId_avitoMessageId")
  @@index([chatId, sentAt])
  @@index([chatId, direction, isRead])
}

model IntegrationState {
  id           Int      @id @default(1)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  updatedAt    DateTime @updatedAt
}

// Сырые входящие события (полезно для дедупа/диагностики)
model WebhookEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  source    String
  eventId   String?
  type      String?

  payload   Json     @default("{}")

  @@index([source, createdAt])
  @@unique([source, eventId])
}
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  role         String   @default("MANAGER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
}

// Настройки AI-ассистента (синглтон, id=1)
model AiAssistant {
  id              Int      @id @default(1)
  enabled         Boolean  @default(false)
  provider        String?  @default("openai")  // "openai" | "deepseek"
  apiKey          String?                        // OpenAI API key
  deepseekApiKey  String?                        // DeepSeek API key
  assistantId     String?
  vectorStoreId   String?
  instructions    String?
  escalatePrompt  String?
  model           String?
  followupEnabled Boolean  @default(true)        // Включить/выключить дожимы
  updatedAt       DateTime @updatedAt
}

// Файлы базы знаний для DeepSeek (хранятся локально в БД)
model KnowledgeBaseFile {
  id        String   @id @default(cuid())
  filename  String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  chunks    KnowledgeBaseChunk[]
}

// Чанки текста из файлов базы знаний
model KnowledgeBaseChunk {
  id         String   @id @default(cuid())
  fileId     String
  file       KnowledgeBaseFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int

  @@index([fileId])
}
